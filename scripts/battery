#!/usr/bin/env sh

get_command() {
	PATH="/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin" command -v "$1"
}

BASENAME="$(get_command basename)"
DBAR="$(get_command _dbar)"
SED="$(get_command sed)"
AWK="$(get_command awk)"
CAT="$(get_command cat)"
ECHO="$(get_command echo)"

get_capacity() {
	path=$1

	if [ -f "$path/capacity" ]; then
		$CAT "$path/capacity"
		return
	fi

	if [ -f "$path/energy_now" ] && [ -f "$path/energy_full" ]; then
		now=$($CAT "$path/energy_now")
		full=$($CAT "$path/energy_full")
		if [ "$full" -gt 0 ] 2>/dev/null; then
			$ECHO $((now * 100 / full))
			return
		fi
	fi

	if [ -f "$path/charge_now" ] && [ -f "$path/charge_full" ]; then
		now=$($CAT "$path/charge_now")
		full=$($CAT "$path/charge_full")
		if [ "$full" -gt 0 ] 2>/dev/null; then
			$ECHO $((now * 100 / full))
			return
		fi
	fi

	echo "?"
}

get_temp() {
	for z in /sys/class/thermal/thermal_zone*; do
		if grep -qiE 'cpu|x86_pkg_temp|package' "$z/type"; then
			awk '{printf("%.1f°C", $1/1000)}' "$z/temp"
			exit 0
		fi
	done

	if [ -f /sys/class/thermal/thermal_zone0/temp ]; then
		awk '{printf("%.1f°C", $1/1000)}' '/sys/class/thermal/thermal_zone0/temp'
	fi
}

charging=0
batteries=""

for b in /sys/class/power_supply/*; do
	[ -f "$b/type" ] || continue
	type=$($CAT "$b/type")
	[ "$type" = "Battery" ] || continue

	name=$($BASENAME "$b" | $SED 's/BAT/B/')

	if [ -f "$b/status" ]; then
		status=$($CAT "$b/status")
		[ "$status" = "Charging" ] && charging=1
	fi

	cap=$(get_capacity "$b")
	battery_bar=$($ECHO "$cap" | $DBAR 10 "$name: ")
	batteries="$batteries $battery_bar"

	if [ -f "$b/power_now" ]; then
		# shellcheck disable=SC2016
		usage=$($AWK '{print $1/1000000 " W"}' "$b/power_now")
		batteries="$batteries ($usage)"
	elif [ -f "$b/current_now" ] && [ -f "$b/voltage_now" ]; then
		# shellcheck disable=SC2016
		usage=$(cat "$b/voltage_now" "$b/current_now" | paste -s | awk '{ printf "%.2f W", $1*$2/1e12}')
		batteries="$batteries ($usage)"
	fi
done

if [ "$charging" -eq 1 ]; then
	prefix="CHRG "
else
	prefix=""
fi

temperature=" ($(get_temp))"
echo "$prefix$batteries$temperature"
